# ──────────────────────────────────────────────────────────────────────────────
# OpenQilin — Environment Configuration Example
# Copy to .env and fill in real values. Never commit .env to version control.
# All OPENQILIN_* vars are read by RuntimeSettings (pydantic-settings,
# env_prefix="OPENQILIN_"). Non-prefixed vars are read by external services
# (Grafana, OTel SDK) or provided as aliases for tooling.
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
OPENQILIN_ENV=local_dev
OPENQILIN_SYSTEM_ROOT=~/.openqilin
OPENQILIN_RUNTIME_PERSISTENCE_ENABLED=false
OPENQILIN_SMOKE_API_BASE_URL=http://127.0.0.1:8000
OPENQILIN_CONNECTOR_SHARED_SECRET=dev-openqilin-secret

# ── Data — PostgreSQL ─────────────────────────────────────────────────────────
# Empty = use InMemory repos (local/test). Set to real DSN in compose/prod.
OPENQILIN_DATABASE_URL=postgresql+psycopg://openqilin:openqilin@localhost:5432/openqilin
# Backward-compatible alias consumed by some DB tooling (e.g. alembic helpers).
# Local compose baseline uses pgvector/pgvector:pg16 to provide the vector extension.
POSTGRES_DSN=postgresql+psycopg://openqilin:openqilin@localhost:5432/openqilin

# ── Data — Redis ──────────────────────────────────────────────────────────────
# Empty = use InMemory idempotency store (local/test). Set to real URL in compose/prod.
OPENQILIN_REDIS_URL=redis://localhost:6379/0
OPENQILIN_IDEMPOTENCY_TTL_SECONDS=86400

# ── Governance — OPA Policy Runtime ──────────────────────────────────────────
# Empty = InMemoryPolicyRuntimeClient (local/test). Set to http://opa:8181 in compose.
OPENQILIN_OPA_URL=http://localhost:8181

# ── LLM Gateway ───────────────────────────────────────────────────────────────
OPENQILIN_LLM_PROVIDER_BACKEND=in_memory
OPENQILIN_LLM_DEFAULT_ROUTING_PROFILE=dev_gemini_free
OPENQILIN_LLM_DEFAULT_MAX_TOKENS=1024
OPENQILIN_LLM_DEFAULT_QUOTA_REQUEST_CAP=1000
OPENQILIN_LLM_DEFAULT_QUOTA_TOKEN_CAP=100000
OPENQILIN_LLM_DEFAULT_ALLOCATION_MODE=hybrid
OPENQILIN_LLM_DEFAULT_PROJECT_SHARE_RATIO=0.1
OPENQILIN_LLM_DEFAULT_BUDGET_WINDOW=daily

# ── LLM Gateway — Gemini ──────────────────────────────────────────────────────
OPENQILIN_GEMINI_API_KEY=replace-me
OPENQILIN_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENQILIN_GEMINI_REQUEST_TIMEOUT_SECONDS=20.0
OPENQILIN_GEMINI_MAX_RETRIES=2
OPENQILIN_GEMINI_RETRY_BASE_DELAY_SECONDS=1.0
OPENQILIN_GEMINI_RETRY_MAX_DELAY_SECONDS=8.0
OPENQILIN_GEMINI_FREE_PRIMARY_MODEL=gemini-2.0-flash
OPENQILIN_GEMINI_FREE_FALLBACK_MODEL=gemini-2.0-flash

# DeepSeek LLM provider (set OPENQILIN_LLM_PROVIDER_BACKEND=deepseek to activate)
OPENQILIN_DEEPSEEK_API_KEY=replace-me
OPENQILIN_DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENQILIN_DEEPSEEK_MODEL=deepseek-chat
OPENQILIN_DEEPSEEK_REQUEST_TIMEOUT_SECONDS=30.0
OPENQILIN_DEEPSEEK_MAX_RETRIES=2
OPENQILIN_DEEPSEEK_RETRY_BASE_DELAY_SECONDS=1.0
OPENQILIN_DEEPSEEK_RETRY_MAX_DELAY_SECONDS=8.0

# Set OPENQILIN_LLM_DEFAULT_ROUTING_PROFILE=dev_deepseek when using the DeepSeek provider

# LiteLLM proxy (optional alternative backend).
LITELLM_BASE_URL=http://localhost:4000

# ── Discord ───────────────────────────────────────────────────────────────────
OPENQILIN_DISCORD_BOT_TOKEN=replace-me
OPENQILIN_DISCORD_MULTI_BOT_ENABLED=false
OPENQILIN_DISCORD_WORKER_ROLE=runtime_agent
OPENQILIN_DISCORD_ROLE_BOT_TOKENS_FILE=.secrets/discord_role_bot_tokens.json
OPENQILIN_DISCORD_ROLE_BOT_TOKENS_JSON={}
OPENQILIN_DISCORD_REQUIRED_ROLE_BOTS_CSV=administrator,auditor,ceo,cwo,project_manager
OPENQILIN_DISCORD_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8000
OPENQILIN_DISCORD_COMMAND_PREFIX=/oq
OPENQILIN_DISCORD_ACTOR_ROLE_DEFAULT=owner
OPENQILIN_DISCORD_ACTOR_ROLE_MAP_JSON={}
OPENQILIN_DISCORD_ALLOWED_GUILD_IDS_CSV=
OPENQILIN_DISCORD_ALLOWED_CHANNEL_IDS_CSV=
OPENQILIN_DISCORD_REQUEST_TIMEOUT_SECONDS=20.0
OPENQILIN_DISCORD_RESPONSE_CHUNK_SIZE_CHARS=1900
OPENQILIN_DISCORD_RESPONSE_RETRY_ATTEMPTS=2
OPENQILIN_DISCORD_RESPONSE_RETRY_BASE_DELAY_SECONDS=0.5

# ── Observability — OpenTelemetry ─────────────────────────────────────────────
# OPENQILIN_OTLP_ENDPOINT: read by RuntimeSettings to configure tracer/metrics/logs.
# Empty = no OTel export (local/test). Set to http://otel_collector:4317 in compose.
OPENQILIN_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_ENDPOINT: standard OTel SDK env var (read by opentelemetry-sdk directly).
# Should match OPENQILIN_OTLP_ENDPOINT.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Observability — LangSmith Dev-Time Tracing ───────────────────────────────
# Set LANGCHAIN_TRACING_V2=true to enable. Disabled by default.
# Not a governance audit source — dev-time LangGraph visibility only.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=openqilin-dev

# ── Grafana Alerts and Public URL ─────────────────────────────────────────────
# OPENQILIN_GRAFANA_PUBLIC_URL: announced in #leadership_council on bot startup.
# Empty = no announcement.
OPENQILIN_GRAFANA_PUBLIC_URL=http://localhost:3000
# DISCORD_ALERT_WEBHOOK_URL: read by the Grafana container (not by Python runtime).
# Set to a Discord webhook URL for the #leadership_council channel.
DISCORD_ALERT_WEBHOOK_URL=replace-me
