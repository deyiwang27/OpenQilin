# Runtime
OPENQILIN_ENV=local_dev
OPENQILIN_SMOKE_API_BASE_URL=http://127.0.0.1:8000

# Data
OPENQILIN_DATABASE_URL=postgresql+psycopg://openqilin:openqilin@localhost:5432/openqilin
# Backward-compatible alias consumed by DB resolution helpers.
POSTGRES_DSN=postgresql+psycopg://openqilin:openqilin@localhost:5432/openqilin
REDIS_URL=redis://localhost:6379/0

# Governance
OPA_BASE_URL=http://localhost:8181

# LLM Gateway
OPENQILIN_LLM_ROUTING_PROFILE=dev_gemini_free
LITELLM_BASE_URL=http://localhost:4000
GEMINI_API_KEY=replace-me

# Identity / Connectors
DISCORD_APPLICATION_ID=replace-me
DISCORD_PUBLIC_KEY=replace-me
DISCORD_BOT_TOKEN=replace-me

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
